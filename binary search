binary search related program


def binary_search(arr,target,left,right)
 if left>right:
   return "not found"
 mid=(left+right)//2
 if arr[mid]==target:
   return mid
 elif arr[mid]>target:
   return binary_search(arr,target,left,mid-1)
 else:
   return binary_search(arr,target,mid+1,right)
arr=[1,2,3,4,5,6,7,]
target=100
print(binary_search(arr,target,0,len(arr)-1)
